#####
# VITEST CONFIGURATION
# Copy and configure the variables below in your own `.env.test.local` file
#####

# URL of h5grove support server
VITE_H5GROVE_URL=http://localhost:8888

# Name of test file
VITE_H5GROVE_TEST_FILE=sample.h5

# Set to `true` to skip testing h5grove API
VITE_H5GROVE_SKIP=

# Path to HDF5 test file, relative to the root of the monorepo
VITE_H5WASM_TEST_FILE=support/sample/dist/sample.h5

# Set to `true` to skip testing h5wasm API
VITE_H5WASM_SKIP=

# Browser to use when testing — `chromium` is required when testing in Docker or with coverage enabled
VITE_TEST_BROWSER=firefox

# Set to `true` to let Vitest connect to a running Playwright Docker container.
# This also enables visual regression testing.
# ```
# docker pull mcr.microsoft.com/playwright:v1.58.1-noble
# docker compose up -d
# VITE_TEST_IN_DOCKER=true VITE_TEST_BROWSER=chromium pnpm test --browser.headless
# ```
VITE_TEST_IN_DOCKER=

# Print full DOM by default
DEBUG_PRINT_LIMIT=1000000
